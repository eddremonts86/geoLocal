# ── Section 1: Application ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# ── Section 2: Database ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_dashboard

# ── Section 3: Authentication ─────────────────────────────────────────────────
AUTH_MODE=hybrid
VITE_AUTH_MODE=hybrid
BETTER_AUTH_SECRET=dev-only-geo-dashboard-secret-change-me-1234567890
BETTER_AUTH_URL=http://localhost:3001
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=

# ── Section 4: Default local admin (seeded by db:seed:admin) ─────────────────
DEFAULT_ADMIN_EMAIL=edd_admin@local.com
DEFAULT_ADMIN_PASSWORD=Passw0rd!234

# ── Section 5: AI — Scraping normaliser (OpenAI-compatible) ──────────────────
# Default provider (MiniMax) is configured in the workspace-root .env via
# MINIMAX_API_KEY / MINIMAX_BASE_URL / MINIMAX_MODEL. The scraper-cron container
# loads that file via `env_file`, and src/shared/lib/ai/config.ts falls back to
# MINIMAX_* when AI_SCRAPER_* is empty. Set AI_SCRAPER_* below ONLY to override
# the workspace default for this app (e.g. point at local llama-cpp / Ollama).
AI_SCRAPER_BASE_URL=
AI_SCRAPER_API_KEY=
AI_SCRAPER_MODEL=
AI_SCRAPER_TIMEOUT_MS=30000
AI_SCRAPER_MAX_RETRIES=2

# ── Section 7: Observability ─────────────────────────────────────────────────
VITE_SENTRY_DSN=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./public/uploads

# ── Payments — Stripe Connect ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_BPS=500
