# geo-dashboard — Production Environment Configuration
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production — only .env.production.example is tracked.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://geo.eduardoinerarte.dk

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=geodash
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=geo_dashboard_prod
DATABASE_URL=postgresql://geodash:change_me_strong_password@db:5432/geo_dashboard_prod

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_MODE=hybrid                       # local | clerk | hybrid
VITE_AUTH_MODE=hybrid
BETTER_AUTH_SECRET=change_me_generate_with_openssl  # openssl rand -base64 32
BETTER_AUTH_URL=https://geo.eduardoinerarte.dk
CLERK_SECRET_KEY=                      # sk_live_... from clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=            # pk_live_... from clerk.com → API Keys

# ── AI — Scraping Normaliser ──────────────────────────────────────────────────
AI_SCRAPER_BASE_URL=https://api.openai.com/v1
AI_SCRAPER_API_KEY=                    # OpenAI or cloud LLM API key
AI_SCRAPER_MODEL=gpt-4o-mini
AI_SCRAPER_TIMEOUT_MS=30000
AI_SCRAPER_MAX_RETRIES=2

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=s3                    # local | s3 | cloudflare-r2
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# ── Payments — Stripe Connect ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=                     # sk_live_... from dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=                # pk_live_...
VITE_STRIPE_PUBLISHABLE_KEY=           # pk_live_... (client-side mirror)
STRIPE_WEBHOOK_SECRET=                 # whsec_... from Stripe → Webhooks
STRIPE_PLATFORM_FEE_BPS=500            # platform fee in basis points (500 = 5%)

# ── Observability ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                       # from sentry.io → Project → DSN
