# geo-dashboard — Environment Configuration
# Copy this file to .env and fill in values for your environment.
# NEVER commit .env — only .env.example is tracked.
#
# NOTE: geo-dashboard runs on port 3001 (not 3000) to allow running alongside
# other apps. DB uses port 5434.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001          # Public base URL (auth redirects, Stripe webhooks)

# ── Database ──────────────────────────────────────────────────────────────────
# Dev DB runs on port 5434 to avoid conflicts when running multiple apps
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_dashboard

# ── Authentication ────────────────────────────────────────────────────────────
AUTH_MODE=hybrid                       # local | clerk | hybrid
VITE_AUTH_MODE=hybrid                  # client-side mirror — must match AUTH_MODE
BETTER_AUTH_SECRET=change-me-use-openssl-rand-base64-32  # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3001  # must match APP_URL
# Clerk (required when AUTH_MODE=clerk or hybrid)
CLERK_SECRET_KEY=                      # sk_test_... from clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=            # pk_test_... from clerk.com → API Keys

# ── AI — Scraping Normaliser ───────────────────────────────────────────────────
# OpenAI-compatible endpoint used by the scraping/listing normaliser pipeline.
# Works with LM Studio, Ollama, OpenAI, vLLM — just change the URL and model.
# Leave AI_SCRAPER_BASE_URL empty to skip AI normalisation (rules-only fallback).
AI_SCRAPER_BASE_URL=http://127.0.0.1:1234/v1  # e.g. http://localhost:11434/v1 for Ollama
AI_SCRAPER_API_KEY=                    # leave empty for local providers
AI_SCRAPER_MODEL=                      # model name (e.g. llama3.2, gpt-4o-mini)
AI_SCRAPER_TIMEOUT_MS=30000            # request timeout in milliseconds
AI_SCRAPER_MAX_RETRIES=2               # retry attempts on transient errors

# ── Observability ─────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=                       # from sentry.io → Project → DSN (empty = disabled)

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local                 # local | s3 | cloudflare-r2
STORAGE_LOCAL_DIR=./public/uploads     # path for local file uploads (dev only)

# ── Payments — Stripe Connect ──────────────────────────────────────────────────
# Required to enable marketplace payment flows. Leave blank to disable Stripe.
STRIPE_SECRET_KEY=                     # sk_test_... from dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=               # pk_test_... (server-side reference)
VITE_STRIPE_PUBLISHABLE_KEY=          # pk_test_... (client-side, same key)
STRIPE_WEBHOOK_SECRET=                # whsec_... from Stripe → Webhooks
STRIPE_PLATFORM_FEE_BPS=500           # platform fee in basis points (500 = 5%)

# ── Default local admin (seeded by db:seed:admin) ────────────────────────────
# Run `pnpm db:seed:admin` after migrations to create the initial admin user.
# These same values live in the workspace-level .env so they stay consistent.
DEFAULT_ADMIN_EMAIL=edd_admin@local.com
DEFAULT_ADMIN_PASSWORD=Passw0rd!234
