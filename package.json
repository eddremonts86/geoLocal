{
  "name": "geo-dashboard",
  "private": true,
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite dev --port 3003",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "db:up": "docker inspect workspace-postgres --format '{{.State.Running}}' 2>/dev/null | grep -q true || docker compose --profile standalone up -d db",
    "dev:all": "pnpm db:up && pnpm db:migrate && pnpm db:seed:admin && pnpm db:seed && pnpm scrape:up && pnpm dev",
    "scrape:up": "docker compose --profile docker up -d scraper-cron",
    "scrape:down": "docker compose --profile docker stop scraper-cron",
    "scrape:logs": "docker compose --profile docker logs -f --tail 200 scraper-cron",
    "scrape:status": "docker compose --profile docker ps scraper-cron",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env scripts/db/create-db.ts && drizzle-kit migrate",
    "db:seed": "tsx --env-file=.env scripts/db/seed.ts",
    "db:seed:legacy": "tsx --env-file=.env scripts/db/seed-legacy.ts",
    "db:seed:vehicles": "tsx --env-file=.env scripts/db/seed-vehicles-extra.ts",
    "db:seed:admin": "tsx --env-file=.env scripts/db/seed-admin.ts",
    "scrape": "tsx scripts/scraping/runner.ts",
    "scrape:airbnb": "tsx scripts/scraping/runner.ts --source airbnb",
    "scrape:facebook": "tsx scripts/scraping/runner.ts --source facebook",
    "scrape:linkedin": "tsx scripts/scraping/runner.ts --source linkedin",
    "scrape:edc": "tsx scripts/scraping/runner.ts --source edc",
    "scrape:homestra": "tsx scripts/scraping/runner.ts --source homestra",
    "scrape:boligsiden": "tsx scripts/scraping/runner.ts --source boligsiden",
    "scrape:boliga": "tsx scripts/scraping/runner.ts --source boliga",
    "scrape:dk": "tsx scripts/scraping/runner.ts --source edc,homestra,boligsiden,boliga",
    "scrape:discover": "tsx scripts/scraping/discovery.ts",
    "scrape:dry": "tsx scripts/scraping/runner.ts --dry-run",
    "scrape:cookies": "tsx scripts/scraping/helpers/save-cookies.ts",
    "scrape:docker:build": "docker compose --profile scraping build scraper",
    "scrape:docker": "docker compose --profile scraping run --rm scraper",
    "scrape:docker:airbnb": "docker compose --profile scraping run --rm scraper --source airbnb",
    "scrape:docker:facebook": "docker compose --profile scraping run --rm scraper --source facebook",
    "scrape:docker:events": "docker compose --profile scraping run --rm scraper --source facebook-events",
    "scrape:docker:linkedin": "docker compose --profile scraping run --rm scraper --source linkedin",
    "scrape:docker:cron:start": "docker compose up -d scraper-cron",
    "scrape:docker:cron:stop": "docker compose stop scraper-cron",
    "scrape:docker:cron:logs": "docker compose logs -f scraper-cron"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.3.1",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-start": "^1.167.32",
    "@tanstack/react-start-client": "^1.166.35",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@tanstack/router-plugin": "^1.167.18",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.8.0",
    "maplibre-gl": "^5.4.0",
    "nuqs": "^2.8.9",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.2",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.6.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^16.4.5",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@parcel/watcher",
      "@percy/core",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
