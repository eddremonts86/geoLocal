# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/geo_dashboard

# Auth
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_SECRET=change-me-in-production-1234567890abcdef

# Storage (local adapter for dev)
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=./public/uploads

# AI — used by the scraping normaliser (OpenAI-compatible /chat/completions)
# Works with LMStudio, Ollama, OpenAI, vLLM, etc. by changing only these vars.
# Leave AI_BASE_URL empty to skip AI normalisation (rules-only fallback).
AI_BASE_URL=http://127.0.0.1:1234/v1
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_MS=30000
AI_MAX_RETRIES=2

# Public app URL (used by Stripe webhooks & redirect URLs)
APP_URL=http://localhost:3001

# Stripe Connect (https://dashboard.stripe.com/apikeys)
# Required to enable the marketplace payments flow. Leave blank to disable.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform fee in basis points (e.g. 500 = 5.00%). Default 500.
STRIPE_PLATFORM_FEE_BPS=500

# Clerk (https://dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
